!<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CS Fundamentals Quiz</title>
    <link rel="stylesheet" href="/style/nav.css">
<style>
     * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  }

body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #74ABE2, #5563DE);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Adjust content below navbar */
.content-wrapper {
  margin-top: 90px; /* navbar height */
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 15px; /* prevents overflow on small screens */
  box-sizing: border-box;
}

.quiz_container {
  background: #ffffff15;
  backdrop-filter: blur(15px);
  border-radius: 16px;
  width: 100%;
  max-width: 800px; /* keeps container inside screen */
  padding: 30px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  margin-bottom: 60px;
}

h1 {
  text-align: center;
  margin-bottom: 25px;
  color: #fff;
  font-size: 2rem;
}

.question {
  background: rgba(255,255,255,0.1);
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.question:hover {
  background: rgba(255,255,255,0.2);
}

.question h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #f3f3f3;
}

label {
  display: block;
  margin-bottom: 8px;
  cursor: pointer;
}

input[type="radio"] {
  accent-color: #00ffbf;
  margin-right: 8px;
}

button {
  background: #00ffc8;
  border: none;
  color: #333;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 10px;
  cursor: pointer;
  margin: 20px auto 0;
  display: block;
  transition: all 0.3s ease;
}

button:hover {
  background: #00bfa5;
  color: #fff;
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media screen and (max-width: 900px) {
  .quiz_container {
    padding: 20px;
  }

  h1 {
    font-size: 1.6rem;
  }

  .question h3 {
    font-size: 1rem;
  }
}

@media screen and (max-width: 600px) {
  /* Ensure navbar links stay inside screen */
  .content-wrapper {
    padding: 0 10px;
  }

  .quiz_container {
    padding: 15px;
  }

  h1 {
    font-size: 1.4rem;
  }

  .question h3 {
    font-size: 0.95rem;
  }

  label {
    font-size: 0.9rem;
  }
}
</style>


</head>
<body>

    <%- include('partials/nav') %>
    
     <div class ="content-wrapper">
       <div class="quiz_container">
         <h1>CS Fundamentals  Quiz</h1>

          <form  action="/submit-cs-quiz" method="POST" id="csForm">

           
<% const questions = [

{
  q: "1. What does CPU stand for?",
  opts: ["Central Processing Unit",
         "Computer Personal Unit",
         "Central Program Unit",
         "Control Processing Unit"]
},

{
  q: "2. Which data structure follows FIFO principle?",
  opts: ["Stack",
         "Queue",
         "Tree",
         "Graph"]
},

{
  q: "3. Which data structure follows LIFO principle?",
  opts: ["Queue",
         "Stack",
         "Linked List",
         "Array"]
},

{
  q: "4. What does RAM stand for?",
  opts: ["Random Access Memory",
         "Read Access Memory",
         "Run Access Memory",
         "Real Allocation Memory"]
},

{
  q: "5. Which OS component manages hardware resources?",
  opts: ["Compiler",
         "Kernel",
         "Loader",
         "Editor"]
},

{
  q: "6. Which protocol is used to transfer web pages?",
  opts: ["FTP",
         "SMTP",
         "HTTP",
         "SNMP"]
},

{
  q: "7. Which language is directly understood by the computer?",
  opts: ["Assembly Language",
         "High Level Language",
         "Machine Language",
         "Java"]
},

{
  q: "8. What is the time complexity of binary search?",
  opts: ["O(n)",
         "O(log n)",
         "O(n log n)",
         "O(1)"]
},

{
  q: "9. Which database model organizes data in tables?",
  opts: ["Hierarchical Model",
         "Network Model",
         "Relational Model",
         "Object Model"]
},

{
  q: "10. Which key uniquely identifies a record in a table?",
  opts: ["Foreign Key",
         "Primary Key",
         "Super Key",
         "Alternate Key"]
},

{
  q: "11. Which network device connects multiple networks?",
  opts: ["Switch",
         "Router",
         "Hub",
         "Repeater"]
},

{
  q: "12. Which concept allows a class to inherit properties of another class?",
  opts: ["Encapsulation",
         "Inheritance",
         "Polymorphism",
         "Abstraction"]
},

{
  q: "13. What is the brain of the computer?",
  opts: ["RAM",
         "CPU",
         "Hard Disk",
         "Motherboard"]
},

{
  q: "14. Which memory is non-volatile?",
  opts: ["RAM",
         "Cache",
         "ROM",
         "Register"]
},

{
  q: "15. Which scheduling algorithm uses time quantum?",
  opts: ["FCFS",
         "SJF",
         "Round Robin",
         "Priority Scheduling"]
}

]; %>
       <% const arr = [] %>

             <% questions.forEach((item , i) =>{ %>

              <div class="question">
                <h3><%=item.q %></h3>
                <% item.opts.forEach((opt , j) => { %>
                       <label>
                         <input type ="radio" name ="q<%= i + 1 %>" value ="<%= opt %>" class ="q<%= i+1 %>" required>
                         <%= opt %>
                       </label>
               <% }) %>
              </div>
             <% })%>

             <button type = "submit" class="btn20-quiz" >Submit Quiz</button>

          </form>

       </div>
     </div>
 <script src ="/script/cs.js"></script>


</body>
</html>