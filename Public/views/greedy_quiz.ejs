<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Greedy Quiz</title>
    <link rel="stylesheet" href="/style/nav.css">
<style>
     
  * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  }

body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #74ABE2, #5563DE);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Adjust content below navbar */
.content-wrapper {
  margin-top: 90px; /* navbar height */
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 15px; /* prevents overflow on small screens */
  box-sizing: border-box;
}

.quiz_container {
  background: #ffffff15;
  backdrop-filter: blur(15px);
  border-radius: 16px;
  width: 100%;
  max-width: 800px; /* keeps container inside screen */
  padding: 30px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  margin-bottom: 60px;
}

h1 {
  text-align: center;
  margin-bottom: 25px;
  color: #fff;
  font-size: 2rem;
}

.question {
  background: rgba(255,255,255,0.1);
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.question:hover {
  background: rgba(255,255,255,0.2);
}

.question h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #f3f3f3;
}

label {
  display: block;
  margin-bottom: 8px;
  cursor: pointer;
}

input[type="radio"] {
  accent-color: #00ffbf;
  margin-right: 8px;
}

button {
  background: #00ffc8;
  border: none;
  color: #333;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 10px;
  cursor: pointer;
  margin: 20px auto 0;
  display: block;
  transition: all 0.3s ease;
}

button:hover {
  background: #00bfa5;
  color: #fff;
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media screen and (max-width: 900px) {
  .quiz_container {
    padding: 20px;
  }

  h1 {
    font-size: 1.6rem;
  }

  .question h3 {
    font-size: 1rem;
  }
}

@media screen and (max-width: 600px) {
  /* Ensure navbar links stay inside screen */
  .content-wrapper {
    padding: 0 10px;
  }

  .quiz_container {
    padding: 15px;
  }

  h1 {
    font-size: 1.4rem;
  }

  .question h3 {
    font-size: 0.95rem;
  }

  label {
    font-size: 0.9rem;
  }
}
</style>


</head>
<body>

    <%- include('partials/nav') %>
    
     <div class ="content-wrapper">
       <div class="quiz_container">
         <h1>Greedy Quiz</h1>

          <form  action="/submit-greedy-quiz" method="POST" id="greedyForm">

           <% const questions = [

{
  q: "1. What is the main idea behind Greedy Algorithm?",
  opts: [
    "Solve subproblems recursively",
    "Make locally optimal choice at each step",
    "Use memoization",
    "Divide problem into halves"
  ]
},

{
  q: "2. Which property must a problem satisfy to apply Greedy?",
  opts: [
    "Overlapping subproblems",
    "Optimal Substructure",
    "Greedy Choice Property",
    "Both Optimal Substructure & Greedy Choice Property"
  ]
},

{
  q: "3. Which of the following problems can be solved using Greedy?",
  opts: [
    "Activity Selection",
    "0/1 Knapsack",
    "Matrix Chain Multiplication",
    "Longest Common Subsequence"
  ]
},

{
  q: "4. In Activity Selection problem, activities are sorted by?",
  opts: [
    "Starting time",
    "Ending time",
    "Duration",
    "Random order"
  ]
},

{
  q: "5. Fractional Knapsack is solved using?",
  opts: [
    "Dynamic Programming",
    "Backtracking",
    "Greedy based on value/weight ratio",
    "Divide and Conquer"
  ]
},

{
  q: "6. Why does 0/1 Knapsack not work correctly with Greedy?",
  opts: [
    "No recursion",
    "No sorting",
    "Greedy choice may not give global optimum",
    "Too many loops"
  ]
},

{
  q: "7. What is the time complexity of Activity Selection?",
  opts: [
    "O(n)",
    "O(n log n)",
    "O(n²)",
    "O(log n)"
  ]
},

{
  q: "8. In Huffman Coding, Greedy choice is based on?",
  opts: [
    "Highest frequency first",
    "Lowest frequency first",
    "Alphabetical order",
    "Longest string first"
  ]
},

{
  q: "9. What data structure is commonly used in Huffman Coding?",
  opts: [
    "Stack",
    "Queue",
    "Priority Queue (Min Heap)",
    "Linked List"
  ]
},

{
  q: "10. Dijkstra’s Algorithm is an example of?",
  opts: [
    "Pure DP",
    "Greedy Algorithm",
    "Backtracking",
    "Divide & Conquer"
  ]
},

{
  q: "11. What is the time complexity of Dijkstra using Min Heap?",
  opts: [
    "O(V + E)",
    "O((V + E) log V)",
    "O(V²)",
    "O(E²)"
  ]
},

{
  q: "12. Which problem uses Greedy strategy of selecting smallest coin first?",
  opts: [
    "Coin Change (for standard denominations)",
    "Longest Path",
    "DFS",
    "Binary Search"
  ]
},

{
  q: "13. Which condition makes Greedy fail?",
  opts: [
    "No optimal substructure",
    "No greedy choice property",
    "Large input size",
    "Recursion depth"
  ]
},

{
  q: "14. Prim’s Algorithm is used for?",
  opts: [
    "Shortest Path",
    "Minimum Spanning Tree",
    "Topological Sort",
    "Cycle Detection"
  ]
},

{
  q: "15. Kruskal’s Algorithm uses which data structure to avoid cycles?",
  opts: [
    "Stack",
    "Queue",
    "Disjoint Set (Union-Find)",
    "Heap"
  ]
}

]; %>

             <% const arr = [] %>

             <% questions.forEach((item , i) =>{ %>

              <div class="question">
                <h3><%=item.q %></h3>
                <% item.opts.forEach((opt , j) => { %>
                       <label>
                         <input type ="radio" name ="q<%= i + 1 %>" value ="<%= opt %>" class ="q<%= i+1 %>" required>
                         <%= opt %>
                       </label>
               <% }) %>
              </div>
             <% })%>

             <button type = "submit" class="btn10-quiz" >Submit Quiz</button>

          </form>

       </div>
     </div>
 <script src ="/script/greedy.js"></script>


</body>
</html>