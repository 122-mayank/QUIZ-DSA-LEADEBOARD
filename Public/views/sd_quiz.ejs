!<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Design Quiz</title>
    <link rel="stylesheet" href="/style/nav.css">
<style>
     * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  }

body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #74ABE2, #5563DE);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Adjust content below navbar */
.content-wrapper {
  margin-top: 90px; /* navbar height */
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 15px; /* prevents overflow on small screens */
  box-sizing: border-box;
}

.quiz_container {
  background: #ffffff15;
  backdrop-filter: blur(15px);
  border-radius: 16px;
  width: 100%;
  max-width: 800px; /* keeps container inside screen */
  padding: 30px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  margin-bottom: 60px;
}

h1 {
  text-align: center;
  margin-bottom: 25px;
  color: #fff;
  font-size: 2rem;
}

.question {
  background: rgba(255,255,255,0.1);
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.question:hover {
  background: rgba(255,255,255,0.2);
}

.question h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #f3f3f3;
}

label {
  display: block;
  margin-bottom: 8px;
  cursor: pointer;
}

input[type="radio"] {
  accent-color: #00ffbf;
  margin-right: 8px;
}

button {
  background: #00ffc8;
  border: none;
  color: #333;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 10px;
  cursor: pointer;
  margin: 20px auto 0;
  display: block;
  transition: all 0.3s ease;
}

button:hover {
  background: #00bfa5;
  color: #fff;
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media screen and (max-width: 900px) {
  .quiz_container {
    padding: 20px;
  }

  h1 {
    font-size: 1.6rem;
  }

  .question h3 {
    font-size: 1rem;
  }
}

@media screen and (max-width: 600px) {
  /* Ensure navbar links stay inside screen */
  .content-wrapper {
    padding: 0 10px;
  }

  .quiz_container {
    padding: 15px;
  }

  h1 {
    font-size: 1.4rem;
  }

  .question h3 {
    font-size: 0.95rem;
  }

  label {
    font-size: 0.9rem;
  }
}
</style>


</head>
<body>

    <%- include('partials/nav') %>
    
     <div class ="content-wrapper">
       <div class="quiz_container">
         <h1>System Design Quiz</h1>

          <form  action="/submit-sd-quiz" method="POST" id="sdForm">

           
<% const questions = [

{
  q: "1. What is the main goal of system design?",
  opts: ["Writing code",
         "Designing scalable and efficient systems",
         "Creating databases only",
         "Improving UI design"]
},

{
  q: "2. What does scalability mean in system design?",
  opts: ["System becomes faster automatically",
         "System can handle increasing number of users or requests",
         "System stores more data",
         "System uses less CPU"]
},

{
  q: "3. Which technique distributes traffic across multiple servers?",
  opts: ["Caching",
         "Load Balancing",
         "Sharding",
         "Indexing"]
},

{
  q: "4. What is the purpose of caching?",
  opts: ["Store frequently accessed data for faster retrieval",
         "Store backup data",
         "Reduce disk space",
         "Encrypt data"]
},

{
  q: "5. Which database is generally preferred for large-scale distributed systems?",
  opts: ["NoSQL",
         "Spreadsheet",
         "Flat File",
         "Manual Storage"]
},

{
  q: "6. What is sharding in system design?",
  opts: ["Splitting database into smaller pieces",
         "Encrypting database",
         "Backing up data",
         "Deleting duplicate data"]
},

{
  q: "7. Which tool is commonly used for in-memory caching?",
  opts: ["MySQL",
         "Redis",
         "MongoDB",
         "Oracle"]
},

{
  q: "8. What problem does load balancing solve?",
  opts: ["Network failure",
         "Uneven distribution of traffic",
         "Database corruption",
         "Memory leakage"]
},

{
  q: "9. What does CAP theorem state?",
  opts: ["Consistency, Availability, Partition Tolerance",
         "Caching, Access, Performance",
         "Capacity, Access, Processing",
         "Control, Allocation, Processing"]
},

{
  q: "10. Which architecture divides application into independent services?",
  opts: ["Monolithic Architecture",
         "Microservices Architecture",
         "Client-only Architecture",
         "Standalone Architecture"]
},

{
  q: "11. What is a CDN mainly used for?",
  opts: ["Database management",
         "Faster content delivery using distributed servers",
         "Load balancing databases",
         "Encrypting network traffic"]
},

{
  q: "12. What is the main advantage of microservices?",
  opts: ["Independent deployment of services",
         "Single large codebase",
         "Single database",
         "No network communication"]
},

{
  q: "13. Which storage is best for storing large media files?",
  opts: ["Object Storage",
         "Cache Memory",
         "CPU Registers",
         "Stack Memory"]
},

{
  q: "14. What is horizontal scaling?",
  opts: ["Adding more servers",
         "Increasing CPU power of one server",
         "Increasing RAM only",
         "Increasing storage"]
},

{
  q: "15. What is a message queue used for?",
  opts: ["Database queries",
         "Asynchronous communication between services",
         "Storing files",
         "Encryption"]
}

]; %>
       <% const arr = [] %>

             <% questions.forEach((item , i) =>{ %>

              <div class="question">
                <h3><%=item.q %></h3>
                <% item.opts.forEach((opt , j) => { %>
                       <label>
                         <input type ="radio" name ="q<%= i + 1 %>" value ="<%= opt %>" class ="q<%= i+1 %>" required>
                         <%= opt %>
                       </label>
               <% }) %>
              </div>
             <% })%>

             <button type = "submit" class="btn17-quiz" >Submit Quiz</button>

          </form>

       </div>
     </div>
 <script src ="/script/sd.js"></script>


</body>
</html>