!<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DBMS Quiz</title>
    <link rel="stylesheet" href="/style/nav.css">
<style>
     * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  }

body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #74ABE2, #5563DE);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Adjust content below navbar */
.content-wrapper {
  margin-top: 90px; /* navbar height */
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 15px; /* prevents overflow on small screens */
  box-sizing: border-box;
}

.quiz_container {
  background: #ffffff15;
  backdrop-filter: blur(15px);
  border-radius: 16px;
  width: 100%;
  max-width: 800px; /* keeps container inside screen */
  padding: 30px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  margin-bottom: 60px;
}

h1 {
  text-align: center;
  margin-bottom: 25px;
  color: #fff;
  font-size: 2rem;
}

.question {
  background: rgba(255,255,255,0.1);
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.question:hover {
  background: rgba(255,255,255,0.2);
}

.question h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #f3f3f3;
}

label {
  display: block;
  margin-bottom: 8px;
  cursor: pointer;
}

input[type="radio"] {
  accent-color: #00ffbf;
  margin-right: 8px;
}

button {
  background: #00ffc8;
  border: none;
  color: #333;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 10px;
  cursor: pointer;
  margin: 20px auto 0;
  display: block;
  transition: all 0.3s ease;
}

button:hover {
  background: #00bfa5;
  color: #fff;
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media screen and (max-width: 900px) {
  .quiz_container {
    padding: 20px;
  }

  h1 {
    font-size: 1.6rem;
  }

  .question h3 {
    font-size: 1rem;
  }
}

@media screen and (max-width: 600px) {
  /* Ensure navbar links stay inside screen */
  .content-wrapper {
    padding: 0 10px;
  }

  .quiz_container {
    padding: 15px;
  }

  h1 {
    font-size: 1.4rem;
  }

  .question h3 {
    font-size: 0.95rem;
  }

  label {
    font-size: 0.9rem;
  }
}
</style>


</head>
<body>

    <%- include('partials/nav') %>
    
     <div class ="content-wrapper">
       <div class="quiz_container">
         <h1>DBMS Quiz</h1>

          <form  action="/submit-dbms-quiz" method="POST" id="dbmsForm">

           
<% const questions = [

{
  q: "1. What does ACID stand for in DBMS?",
  opts: ["Atomicity, Consistency, Isolation, Durability",
         "Accuracy, Consistency, Isolation, Durability",
         "Atomicity, Concurrency, Integrity, Durability",
         "Access, Control, Isolation, Data"]
},

{
  q: "2. Which normal form removes partial dependency?",
  opts: ["1NF", "2NF", "3NF", "BCNF"]
},

{
  q: "3. Which normal form removes transitive dependency?",
  opts: ["1NF", "2NF", "3NF", "4NF"]
},

{
  q: "4. What is a Super Key?",
  opts: ["A key with minimal attributes",
         "A set of attributes that uniquely identifies a tuple",
         "Primary key only",
         "Foreign key"]
},

{
  q: "5. Which isolation level prevents dirty reads?",
  opts: ["Read Uncommitted",
         "Read Committed",
         "Repeatable Read",
         "Serializable"]
},

{
  q: "6. What is the time complexity of searching in B+ Tree?",
  opts: ["O(n)", "O(log n)", "O(n log n)", "O(1)"]
},

{
  q: "7. Which join returns rows when there is a match in both tables?",
  opts: ["LEFT JOIN", "RIGHT JOIN", "FULL JOIN", "INNER JOIN"]
},

{
  q: "8. What is a Deadlock in DBMS?",
  opts: ["Infinite loop",
         "Two transactions waiting for each other",
         "Data redundancy",
         "Loss of data"]
},

{
  q: "9. Which protocol is used to ensure serializability?",
  opts: ["Two Phase Locking",
         "Indexing",
         "Normalization",
         "Hashing"]
},

{
  q: "10. What does BCNF ensure?",
  opts: ["No multivalued dependency",
         "Every determinant is a candidate key",
         "No transitive dependency",
         "No partial dependency"]
},

{
  q: "11. Which indexing technique uses hash function?",
  opts: ["B+ Tree",
         "Clustered Index",
         "Hash Index",
         "Dense Index"]
},

{
  q: "12. Which anomaly occurs due to poor normalization?",
  opts: ["Insertion anomaly",
         "Update anomaly",
         "Deletion anomaly",
         "All of the above"]
},

{
  q: "13. What is a Candidate Key?",
  opts: ["Primary key only",
         "A minimal super key",
         "Foreign key",
         "Composite key"]
},

{
  q: "14. Which schedule ensures conflict serializability?",
  opts: ["Recoverable schedule",
         "Non-serial schedule",
         "Serializable schedule",
         "Cascading schedule"]
},

{
  q: "15. What is Shadow Paging used for?",
  opts: ["Indexing",
         "Query Optimization",
         "Recovery Management",
         "Normalization"]
}

]; %>
             <% const arr = [] %>

             <% questions.forEach((item , i) =>{ %>

              <div class="question">
                <h3><%=item.q %></h3>
                <% item.opts.forEach((opt , j) => { %>
                       <label>
                         <input type ="radio" name ="q<%= i + 1 %>" value ="<%= opt %>" class ="q<%= i+1 %>" required>
                         <%= opt %>
                       </label>
               <% }) %>
              </div>
             <% })%>

             <button type = "submit" class="btn14-quiz" >Submit Quiz</button>

          </form>

       </div>
     </div>
 <script src ="/script/dbms.js"></script>


</body>
</html>