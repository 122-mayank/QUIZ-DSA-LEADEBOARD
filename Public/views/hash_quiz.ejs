!<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hashing Quiz</title>
    <link rel="stylesheet" href="/style/nav.css">
<style>
     * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  }

body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #74ABE2, #5563DE);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Adjust content below navbar */
.content-wrapper {
  margin-top: 90px; /* navbar height */
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 15px; /* prevents overflow on small screens */
  box-sizing: border-box;
}

.quiz_container {
  background: #ffffff15;
  backdrop-filter: blur(15px);
  border-radius: 16px;
  width: 100%;
  max-width: 800px; /* keeps container inside screen */
  padding: 30px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  margin-bottom: 60px;
}

h1 {
  text-align: center;
  margin-bottom: 25px;
  color: #fff;
  font-size: 2rem;
}

.question {
  background: rgba(255,255,255,0.1);
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.question:hover {
  background: rgba(255,255,255,0.2);
}

.question h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #f3f3f3;
}

label {
  display: block;
  margin-bottom: 8px;
  cursor: pointer;
}

input[type="radio"] {
  accent-color: #00ffbf;
  margin-right: 8px;
}

button {
  background: #00ffc8;
  border: none;
  color: #333;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 10px;
  cursor: pointer;
  margin: 20px auto 0;
  display: block;
  transition: all 0.3s ease;
}

button:hover {
  background: #00bfa5;
  color: #fff;
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media screen and (max-width: 900px) {
  .quiz_container {
    padding: 20px;
  }

  h1 {
    font-size: 1.6rem;
  }

  .question h3 {
    font-size: 1rem;
  }
}

@media screen and (max-width: 600px) {
  /* Ensure navbar links stay inside screen */
  .content-wrapper {
    padding: 0 10px;
  }

  .quiz_container {
    padding: 15px;
  }

  h1 {
    font-size: 1.4rem;
  }

  .question h3 {
    font-size: 0.95rem;
  }

  label {
    font-size: 0.9rem;
  }
}
</style>


</head>
<body>

    <%- include('partials/nav') %>
    
     <div class ="content-wrapper">
       <div class="quiz_container">
         <h1>Hashing Quiz</h1>

          <form  action="/submit-hash-quiz" method="POST" id="hashForm">

           

<% const questions = [

{
  q: "1. What is the average time complexity of search in HashMap?",
  opts: ["O(1)", "O(n)", "O(log n)", "O(n log n)"]
},

{
  q: "2. What causes collision in hashing?",
  opts: [
    "Two keys map to same index",
    "Array overflow",
    "Sorting error",
    "Memory leak"
  ]
},

{
  q: "3. Which technique is used to resolve collisions?",
  opts: [
    "Binary Search",
    "Chaining",
    "Merge Sort",
    "Recursion"
  ]
},

{
  q: "4. In Open Addressing, which method probes next index sequentially?",
  opts: [
    "Quadratic Probing",
    "Double Hashing",
    "Linear Probing",
    "Separate Chaining"
  ]
},

{
  q: "5. What is the worst-case time complexity of HashMap search?",
  opts: ["O(1)", "O(n)", "O(log n)", "O(n²)"]
},

{
  q: "6. Which data structure is commonly used in Separate Chaining?",
  opts: [
    "Stack",
    "Linked List",
    "Heap",
    "Tree only"
  ]
},

{
  q: "7. What is Load Factor in hashing?",
  opts: [
    "Number of collisions",
    "Size of array",
    "n / table size",
    "Hash function value"
  ]
},

{
  q: "8. Rehashing is done when?",
  opts: [
    "Load factor exceeds threshold",
    "Array is empty",
    "Key not found",
    "Sorting required"
  ]
},

{
  q: "9. Which problem is commonly solved using Hashing?",
  opts: [
    "Two Sum",
    "Heap Sort",
    "DFS",
    "Binary Search Tree balancing"
  ]
},

{
  q: "10. What is the time complexity of checking duplicates using HashSet?",
  opts: ["O(n)", "O(n²)", "O(log n)", "O(1)"]
},

{
  q: "11. In hashing, what makes a good hash function?",
  opts: [
    "Produces many collisions",
    "Uniform distribution",
    "Always returns 0",
    "Depends only on array size"
  ]
},

{
  q: "12. Which hashing technique avoids clustering better?",
  opts: [
    "Linear Probing",
    "Quadratic Probing",
    "Double Hashing",
    "Chaining"
  ]
},

{
  q: "13. What is the space complexity of HashMap?",
  opts: ["O(1)", "O(n)", "O(log n)", "O(n²)"]
},

{
  q: "14. Which data structure in Java maintains insertion order in hashing?",
  opts: [
    "HashMap",
    "TreeMap",
    "LinkedHashMap",
    "Hashtable"
  ]
},

{
  q: "15. What is the worst-case time complexity of rehashing?",
  opts: ["O(n)", "O(1)", "O(log n)", "O(n²)"]
}

]; %>

             <% const arr = [] %>

             <% questions.forEach((item , i) =>{ %>

              <div class="question">
                <h3><%=item.q %></h3>
                <% item.opts.forEach((opt , j) => { %>
                       <label>
                         <input type ="radio" name ="q<%= i + 1 %>" value ="<%= opt %>" class ="q<%= i+1 %>" required>
                         <%= opt %>
                       </label>
               <% }) %>
              </div>
             <% })%>

             <button type = "submit" class="btn12-quiz" >Submit Quiz</button>

          </form>

       </div>
     </div>
 <script src ="/script/hash.js"></script>


</body>
</html>