<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dynamic Programming  Quiz</title>
    <link rel="stylesheet" href="/style/nav.css">
<style>
     * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  }

body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #74ABE2, #5563DE);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Adjust content below navbar */
.content-wrapper {
  margin-top: 90px; /* navbar height */
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 15px; /* prevents overflow on small screens */
  box-sizing: border-box;
}

.quiz_container {
  background: #ffffff15;
  backdrop-filter: blur(15px);
  border-radius: 16px;
  width: 100%;
  max-width: 800px; /* keeps container inside screen */
  padding: 30px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  margin-bottom: 60px;
}

h1 {
  text-align: center;
  margin-bottom: 25px;
  color: #fff;
  font-size: 2rem;
}

.question {
  background: rgba(255,255,255,0.1);
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.question:hover {
  background: rgba(255,255,255,0.2);
}

.question h3 {
  font-size: 1.1rem;
  margin-bottom: 10px;
  color: #f3f3f3;
}

label {
  display: block;
  margin-bottom: 8px;
  cursor: pointer;
}

input[type="radio"] {
  accent-color: #00ffbf;
  margin-right: 8px;
}

button {
  background: #00ffc8;
  border: none;
  color: #333;
  padding: 12px 25px;
  font-size: 1rem;
  border-radius: 10px;
  cursor: pointer;
  margin: 20px auto 0;
  display: block;
  transition: all 0.3s ease;
}

button:hover {
  background: #00bfa5;
  color: #fff;
  transform: scale(1.05);
}

/* ===== Responsive ===== */
@media screen and (max-width: 900px) {
  .quiz_container {
    padding: 20px;
  }

  h1 {
    font-size: 1.6rem;
  }

  .question h3 {
    font-size: 1rem;
  }
}

@media screen and (max-width: 600px) {
  /* Ensure navbar links stay inside screen */
  .content-wrapper {
    padding: 0 10px;
  }

  .quiz_container {
    padding: 15px;
  }

  h1 {
    font-size: 1.4rem;
  }

  .question h3 {
    font-size: 0.95rem;
  }

  label {
    font-size: 0.9rem;
  }
}
</style>


</head>
<body>

    <%- include('partials/nav') %>
    
     <div class ="content-wrapper">
       <div class="quiz_container">
         <h1>Dynamic Programming Quiz</h1>

          <form  action="/submit-dp-quiz" method="POST" id="dpForm">

            <% const questions = [

{
  q: "1. What are the two main properties required for Dynamic Programming?",
  opts: [
    "Greedy choice & Sorting",
    "Optimal Substructure & Overlapping Subproblems",
    "Recursion & Stack",
    "Divide & Conquer only"
  ]
},

{
  q: "2. Which of the following problems does NOT typically use DP?",
  opts: [
    "0/1 Knapsack",
    "Longest Common Subsequence",
    "Binary Search",
    "Matrix Chain Multiplication"
  ]
},

{
  q: "3. What is the time complexity of solving Fibonacci using memoization?",
  opts: [
    "O(2^n)",
    "O(n)",
    "O(log n)",
    "O(n²)"
  ]
},

{
  q: "4. In 0/1 Knapsack, what does dp[i][w] represent?",
  opts: [
    "Maximum value using first i items and capacity w",
    "Total weight of items",
    "Number of subsets",
    "Minimum weight possible"
  ]
},

{
  q: "5. What is the difference between Top-Down and Bottom-Up DP?",
  opts: [
    "Top-Down uses iteration, Bottom-Up uses recursion",
    "Top-Down uses memoization, Bottom-Up uses tabulation",
    "Both are same",
    "Bottom-Up is always faster"
  ]
},

{
  q: "6. What is the time complexity of Longest Common Subsequence (LCS)?",
  opts: [
    "O(n + m)",
    "O(n*m)",
    "O(2^n)",
    "O(n log m)"
  ]
},

{
  q: "7. Which DP problem uses partitioning strategy?",
  opts: [
    "Matrix Chain Multiplication",
    "Binary Search",
    "Heap Sort",
    "DFS"
  ]
},

{
  q: "8. What is the state transition in Fibonacci DP?",
  opts: [
    "dp[n] = dp[n-1]",
    "dp[n] = dp[n-1] + dp[n-2]",
    "dp[n] = dp[n/2]",
    "dp[n] = n * dp[n-1]"
  ]
},

{
  q: "9. What is the space complexity of bottom-up Fibonacci?",
  opts: [
    "O(1)",
    "O(n)",
    "O(log n)",
    "O(n²)"
  ]
},

{
  q: "10. Which problem is solved using DP on subsequences?",
  opts: [
    "Longest Increasing Subsequence",
    "Merge Sort",
    "Binary Heap",
    "BFS"
  ]
},

{
  q: "11. What is the worst-case time complexity of 0/1 Knapsack?",
  opts: [
    "O(n)",
    "O(nW)",
    "O(W log n)",
    "O(2^n)"
  ]
},

{
  q: "12. In DP on grids, what is commonly used?",
  opts: [
    "Adjacency list",
    "2D DP array",
    "Stack only",
    "Queue only"
  ]
},

{
  q: "13. Which technique reduces DP space complexity?",
  opts: [
    "Pruning",
    "Rolling Array Technique",
    "Sorting",
    "Greedy"
  ]
},

{
  q: "14. What is the time complexity of Matrix Chain Multiplication DP?",
  opts: [
    "O(n²)",
    "O(n³)",
    "O(2^n)",
    "O(n log n)"
  ]
},

{
  q: "15. Which of the following is an example of DP with Bitmasking?",
  opts: [
    "Travelling Salesman Problem (TSP)",
    "Binary Search",
    "Heap Sort",
    "Quick Sort"
  ]
}

]; %>

             <% const arr = [] %>

             <% questions.forEach((item , i) =>{ %>

              <div class="question">
                <h3><%=item.q %></h3>
                <% item.opts.forEach((opt , j) => { %>
                       <label>
                         <input type ="radio" name ="q<%= i + 1 %>" value ="<%= opt %>" class ="q<%= i+1 %>" required>
                         <%= opt %>
                       </label>
               <% }) %>
              </div>
             <% })%>

             <button type = "submit" class="btn9-quiz" >Submit Quiz</button>

          </form>

       </div>
     </div>
 <script src ="/script/dp.js"></script>


</body>
</html>